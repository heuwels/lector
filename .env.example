# Lector Configuration
# Copy to .env.local and adjust as needed

# ── Deployment mode ──────────────────────────────────────────────────────────
# "selfhost" (default) or "cloud". Leave unset for a self-hosted instance —
# unset behaves exactly as every release to date. "cloud" is the future managed
# offering (#216) and REFUSES TO BOOT until accounts/auth ship (#218): the seam
# is in place (#242), the product is not. Unknown values also refuse to boot.
# LECTOR_MODE=selfhost
#
# The one exception (the cloud *canary*, see deploy/cloud/): if an
# authenticating gateway (e.g. Cloudflare Access) fronts EVERY request,
# declaring it lets cloud mode boot with app-level auth delegated to the gate.
# LECTOR_CLOUD_GATE=external
#
# Trust a forwarded client IP only when the origin is exclusively reachable
# through this proxy topology. The managed CDK stack sets this because it has
# no inbound listener and cloudflared is the sole path to the app.
# LECTOR_TRUSTED_PROXY=cloudflare
#
# Hosted Paddle deployments may derive a bounded Free plan for accounts with
# no entitled subscription. Exact lowercase `true` is required; leave unset
# for the existing paid-only gate. Production prerequisites are documented in
# deploy/cloud/README.md.
# LECTOR_FREE_TIER=false
# Optional JSON tuning for plan allowances. Hosted Free accepts finite numeric
# values only (null cannot disable a boundary); `max*` values may be lowered but
# not raised above the defaults proven to fit the 90 MiB restore envelope. Its
# rich managed-AI and managed TTS pools stay fixed at zero. See deploy/cloud/README.md.
# LECTOR_PLAN_LIMITS='{"free":{"maxVocabEntries":10000}}'

# ── API origin (browser → Hono) ──────────────────────────────────────────────
# The browser talks to the Hono API directly (there is no Next.js proxy — #188).
# In local dev it reaches the API at http://localhost:3457 (the `npm run dev:api`
# port) automatically — nothing to set here. For a deployed container the
# browser-facing origin is set via the API_URL env var (see deploy/.env.example);
# it's injected into /__env.js at container start, not read from this file.

# LLM provider for translations: "anthropic" (cloud) or "openai" (any
# OpenAI-compatible local / self-hosted server — Ollama, LM Studio, Apfel, vLLM, …)
LLM_PROVIDER=anthropic

# OpenAI-compatible server settings (used when LLM_PROVIDER=openai).
# One config for every local/self-hosted backend that speaks /v1/chat/completions.
#   OPENAI_COMPAT_URL     — base URL; the app appends /v1
#   OPENAI_COMPAT_MODEL   — model the server serves (e.g. llama3.1:8b)
#   OPENAI_COMPAT_API_KEY — optional; sent as a Bearer token (proxied/cloud setups)
OPENAI_COMPAT_URL=http://localhost:11434
OPENAI_COMPAT_MODEL=llama3.1:8b
# OPENAI_COMPAT_API_KEY=

# Hosted Free deployments pin the three bounded managed translation paths to
# Gemini 2.5 Flash-Lite through OpenRouter. These are optional in self-hosted
# mode; see deploy/cloud/README.md for the strict production rollout contract.
# OPENAI_COMPAT_WORD_GLOSS_MODEL=google/gemini-2.5-flash-lite
# OPENAI_COMPAT_SIMPLE_PHRASE_MODEL=google/gemini-2.5-flash-lite
# OPENAI_COMPAT_SIMPLE_CONTEXT_MODEL=google/gemini-2.5-flash-lite

# Deprecated — the old per-provider vars are still read as fallbacks so existing
# setups keep working, but prefer OPENAI_COMPAT_* above.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# APFEL_URL=http://localhost:11434
# LMSTUDIO_URL=http://localhost:1234
# LMSTUDIO_MODEL=
# LMSTUDIO_API_KEY=

# Anthropic API key (only needed when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Claude OAuth token (Pro/Team plan credits — preferred over API key)
# Obtain via: claude setup-token
CLAUDE_OAUTH_TOKEN=

# Anthropic models. Use plain aliases (no date suffix) so they don't get retired
# out from under you. ANTHROPIC_MODEL is the general default; the three per-task
# vars below override it for specific jobs and fall back to it when unset:
#   word translation    → high volume, single words — Haiku is cheap & fast.
#                          Also drives the streamed /translate/gloss fast path,
#                          so keeping it on Haiku is the biggest latency win.
#   phrase / in-context  → wants more nuance — Sonnet, or Opus if results need it
#   chat (LLM tutor)     → Sonnet, or Opus for richer explanations
# OpenAI-compatible hosted deployments can independently pin the three cheap
# translation tasks above; the richer tasks continue to use their base model.
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_WORD_MODEL=claude-haiku-4-5
# ANTHROPIC_PHRASE_MODEL=claude-sonnet-4-6
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# Google Cloud API key for TTS (optional)
GOOGLE_CLOUD_API_KEY=

# ── Cost controls (#226) ─────────────────────────────────────────────────────
# Synthesized TTS audio is cached (keyed by language+voice+rate+text) and
# replays are served without re-billing Google. Default: on, on disk under
# DATA_DIR/tts-cache with LRU eviction at 1 GiB.
# TTS_CACHE=0                 # disable entirely
# TTS_CACHE_MAX_BYTES=        # disk cap in bytes (default 1073741824 = 1 GiB)
# TTS_CACHE_S3_BUCKET=        # cache in S3-compatible object storage instead of
#                             # disk (cloud/multi-instance); credentials via the
#                             # standard AWS_*/S3_* env vars. No eviction — use a
#                             # bucket lifecycle rule.
# TTS_CACHE_S3_REGION=
# TTS_CACHE_S3_PREFIX=        # object key prefix (default tts-cache/)
# TTS_CACHE_S3_ENDPOINT=      # for R2 / MinIO / other S3-compatibles
#
# The word→domain classifier automatically uses the provider's Batch API (50%
# of synchronous pricing; currently Anthropic with API-key auth) when
# available. Providers without a batch endpoint stay synchronous.
# CLASSIFY_BATCH=0            # force synchronous classification
# CLASSIFY_BATCH_MAX_REQUESTS=40  # prompts per batch (× CLASSIFY_BATCH_SIZE words)

# ── Error tracking & tracing (Sentry) ───────────────────────────────────────
# Optional, opt-in — the SDK stays dormant unless a DSN is set. One project
# covers all three tiers: the browser front-end, the Hono API, and the in-process
# classify-worker, joined by distributed tracing.
#
# DSN (not secret — the browser SDK embeds it by design). SENTRY_DSN configures
# the Hono API + the Next server; NEXT_PUBLIC_SENTRY_DSN is the build-time client
# fallback for local `next dev`. On the prebuilt image the browser reads the DSN
# at runtime from /__env.js (docker-entrypoint.sh writes SENTRY_DSN into it), so
# setting SENTRY_DSN alone suffices there.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Trace sample rate (0.0–1.0). Defaults to 1.0 (full); lower on a busy deploy.
# SENTRY_TRACES_SAMPLE_RATE=1.0
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1.0
# Verbose SDK logging to debug event delivery. SENTRY_DEBUG → API + Next server;
# NEXT_PUBLIC_SENTRY_DEBUG → browser.
# SENTRY_DEBUG=1
# NEXT_PUBLIC_SENTRY_DEBUG=1
# Source-map upload for un-minified production front-end stack traces. Runs
# during `next build` only; a no-op without the token. Token: sentry.io →
# Settings → Auth Tokens (needs the project:releases scope).
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
