# Lector Configuration
# Copy to .env.local and adjust as needed

# ── Deployment mode ──────────────────────────────────────────────────────────
# "selfhost" (default) or "cloud". Leave unset for a self-hosted instance —
# unset behaves exactly as every release to date. "cloud" is the future managed
# offering (#216) and REFUSES TO BOOT until accounts/auth ship (#218): the seam
# is in place (#242), the product is not. Unknown values also refuse to boot.
# LECTOR_MODE=selfhost
#
# The one exception (the cloud *canary*, see deploy/cloud/): if an
# authenticating gateway (e.g. Cloudflare Access) fronts EVERY request,
# declaring it lets cloud mode boot with app-level auth delegated to the gate.
# LECTOR_CLOUD_GATE=external

# ── API origin (browser → Hono) ──────────────────────────────────────────────
# The browser talks to the Hono API directly (there is no Next.js proxy — #188).
# In local dev it reaches the API at http://localhost:3457 (the `npm run dev:api`
# port) automatically — nothing to set here. For a deployed container the
# browser-facing origin is set via the API_URL env var (see deploy/.env.example);
# it's injected into /__env.js at container start, not read from this file.

# LLM provider for translations: "anthropic" (cloud) or "openai" (any
# OpenAI-compatible local / self-hosted server — Ollama, LM Studio, Apfel, vLLM, …)
LLM_PROVIDER=anthropic

# OpenAI-compatible server settings (used when LLM_PROVIDER=openai).
# One config for every local/self-hosted backend that speaks /v1/chat/completions.
#   OPENAI_COMPAT_URL     — base URL; the app appends /v1
#   OPENAI_COMPAT_MODEL   — model the server serves (e.g. llama3.1:8b)
#   OPENAI_COMPAT_API_KEY — optional; sent as a Bearer token (proxied/cloud setups)
OPENAI_COMPAT_URL=http://localhost:11434
OPENAI_COMPAT_MODEL=llama3.1:8b
# OPENAI_COMPAT_API_KEY=

# Deprecated — the old per-provider vars are still read as fallbacks so existing
# setups keep working, but prefer OPENAI_COMPAT_* above.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# APFEL_URL=http://localhost:11434
# LMSTUDIO_URL=http://localhost:1234
# LMSTUDIO_MODEL=
# LMSTUDIO_API_KEY=

# Anthropic API key (only needed when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Claude OAuth token (Pro/Team plan credits — preferred over API key)
# Obtain via: claude setup-token
CLAUDE_OAUTH_TOKEN=

# Anthropic models. Use plain aliases (no date suffix) so they don't get retired
# out from under you. ANTHROPIC_MODEL is the general default; the three per-task
# vars below override it for specific jobs and fall back to it when unset:
#   word translation    → high volume, single words — Haiku is cheap & fast.
#                          Also drives the streamed /translate/gloss fast path,
#                          so keeping it on Haiku is the biggest latency win.
#   phrase / in-context  → wants more nuance — Sonnet, or Opus if results need it
#   chat (LLM tutor)     → Sonnet, or Opus for richer explanations
# Per-task models are Anthropic-only for now; other providers use their single model.
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_WORD_MODEL=claude-haiku-4-5
# ANTHROPIC_PHRASE_MODEL=claude-sonnet-4-6
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# Google Cloud API key for TTS (optional)
GOOGLE_CLOUD_API_KEY=

# Sentry/GlitchTip error tracking (optional, opt-in)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
