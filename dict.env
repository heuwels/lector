# Pinned on-device dictionary releases — single source of truth.
# Sourced by the Dockerfile (dict stage) and the CI workflows. Per language:
#   DICT_VERSION_<LANG>  release tag holding dictionary-<lang>.db
#   DICT_SHA256_<LANG>   sha256 of that asset
# DICT_LANGS lists which languages are baked into the image / fetched by CI.
# Regenerate a language with: scripts/release-dict.sh <lang>
DICT_LANGS="af de es"

# af
DICT_VERSION_AF=dict-af-2026-06-19
DICT_SHA256_AF=d8620401a3696f0f547b9c8af5a507b3c83d9d0971af35db79a9e4e9491854cb

# de
DICT_VERSION_DE=dict-de-2026-06-25
DICT_SHA256_DE=5eec9eb09eb9bbf55893e614be92003f402b2a1a1cb71345305083a22ded6a4b

# es
DICT_VERSION_ES=dict-es-2026-06-26
DICT_SHA256_ES=eb00c37f29c809d28c466505f21b07df1232fb622db6e591c92c0f4d2782286b
