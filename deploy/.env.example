# Lector Configuration
# Copy to .env and adjust as needed

# Image version - pin to a specific version or use 'latest'
LECTOR_VERSION=latest

# Host port for web interface
WEB_PORT=3400

# Persistent data location
DATA_PATH=./data

# LLM provider for translations: "anthropic" (cloud) or "openai" (OpenAI-compatible
# local/self-hosted server — the bundled Ollama service, LM Studio, vLLM, …)
LLM_PROVIDER=anthropic

# Model served by the OpenAI-compatible backend (used when LLM_PROVIDER=openai)
OPENAI_COMPAT_MODEL=llama3.1:8b

# Anthropic API key (only needed when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Claude OAuth token (Pro/Team plan credits — preferred over API key)
# Obtain via: claude setup-token
CLAUDE_OAUTH_TOKEN=

# Sentry/GlitchTip error tracking (optional, opt-in)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
