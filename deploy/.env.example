# Lector Configuration
# Copy to .env and adjust as needed

# Image version - pin to a specific version or use 'latest'
LECTOR_VERSION=latest

# Deployment mode: "selfhost" (default) or "cloud". Leave as-is for a
# self-hosted instance. "cloud" is the future managed offering and refuses to
# boot until accounts/auth ship (heuwels/lector#218; seam tracked in #242).
LECTOR_MODE=selfhost

# Host port for the web interface
WEB_PORT=3400

# Browser-facing API origin. The web app (in the user's browser) calls the Hono
# API directly, so set this to the URL the browser uses to reach it: your host
# plus the API's published port (3457) — e.g. http://lector.my-host:3457. Must be
# reachable FROM THE BROWSER, not an internal Docker name. Injected into
# /__env.js at container start. Unset → falls back to http://localhost:3457
# (only correct when browsing from the Docker host itself).
API_URL=http://localhost:3457

# Persistent data location
DATA_PATH=./data

# LLM provider for translations: "anthropic" (cloud) or "openai" (OpenAI-compatible
# local/self-hosted server — the bundled Ollama service, LM Studio, vLLM, …)
LLM_PROVIDER=anthropic

# Model served by the OpenAI-compatible backend (used when LLM_PROVIDER=openai)
OPENAI_COMPAT_MODEL=llama3.1:8b

# Anthropic API key (only needed when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Claude OAuth token (Pro/Team plan credits — preferred over API key)
# Obtain via: claude setup-token
CLAUDE_OAUTH_TOKEN=

# Sentry/GlitchTip error tracking (optional, opt-in)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
