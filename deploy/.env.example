# Lector Configuration
# Copy to .env and adjust as needed

# Image version - pin to a specific version or use 'latest'
LECTOR_VERSION=latest

# Host port for web interface
WEB_PORT=3400

# Persistent data location
DATA_PATH=./data

# LLM provider for translations: "ollama" (default, local) or "anthropic" (cloud)
LLM_PROVIDER=anthropic

# Ollama model (used when LLM_PROVIDER=anthropic)
OLLAMA_MODEL=llama3.1:8b

# Anthropic API key (only needed when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
