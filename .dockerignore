# Dependencies
node_modules
npm-debug.log*
# api/bun.lock is committed and included in the build context — the image's
# `bun install --frozen-lockfile` installs exactly the locked tree (#236).

# Next.js build output
.next
out

# Testing
coverage

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment files (will be passed via docker-compose)
.env
.env.*
!.env.example

# Git
.git
.gitignore

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# Docs
README.md
*.md

# Backups
backups/

# Local data — user DBs and the dictionary that the `dict` build stage
# fetches fresh from a release. Excluding these keeps stale local files out
# of the image and shrinks the build context.
data/
tmp/
