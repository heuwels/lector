# Dependencies
node_modules
npm-debug.log*
# api/ gitignores its bun.lock, so CI builds with no lockfile and resolves deps
# fresh from package.json. Keep any local (possibly stale) bun.lock out of the
# build context too, so local image builds behave identically — a stale local
# lock otherwise fails the image's frozen `bun install`.
api/bun.lock

# Next.js build output
.next
out

# Testing
coverage

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment files (will be passed via docker-compose)
.env
.env.*
!.env.example

# Git
.git
.gitignore

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# Docs
README.md
*.md

# Backups
backups/

# Local data — user DBs and the dictionary that the `dict` build stage
# fetches fresh from a release. Excluding these keeps stale local files out
# of the image and shrinks the build context.
data/
tmp/
